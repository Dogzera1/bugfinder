# ============================================================
# Bug Finder - configuração
# Copie para .env e ajuste. NUNCA commite o .env real.
# ============================================================

# --- Detector: filtros duros (descartam ofertas) ---
# Desconto mínimo (%) pra considerar candidato
MIN_DISCOUNT_PCT=20
# Faixa de preço aceita (BRL)
MIN_PRICE_BRL=50
MAX_PRICE_BRL=15000
# Rating mínimo (0..1) — ofertas sem rating passam mesmo abaixo
MIN_RATING_SCORE=0.5

# --- Detector: pesos do score (somam ~1) ---
W_DISCOUNT=0.6
W_RATING=0.3
W_POPULARITY=0.1

# --- Threshold pra virar candidato ---
MIN_SCORE=0.25

# --- Storage ---
DB_PATH=data/bugfinder.db

# --- Mercado Livre (Fase 2 — referência de preço de revenda) ---
# Como obter:
# 1. Acesse https://developers.mercadolivre.com.br
# 2. Crie uma app (qualquer redirect URI serve, ex: https://localhost)
# 3. Habilite o grant 'client_credentials' nas configurações da app
# 4. Copie Client ID e Client Secret abaixo
ML_SITE_ID=MLB
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# --- Calculadora de viabilidade ---
# Taxa ML média (Clássico ~12%, Premium ~17%)
ML_FEE_PCT=0.14
# Frete que você paga pra receber a oferta (em geral 0 se for free shipping)
FREIGHT_BUY=0
# Frete que você absorve no anúncio do ML (estimativa, varia por item/região)
FREIGHT_SELL=20
# ROI mínimo (%) para aparecer como candidato após enrichment ML
# 0 = mostra todos; 15 = só mostra se ROI estimado ≥ 15%
MIN_ROI_PCT=0

# --- Telegram (Fase 5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
